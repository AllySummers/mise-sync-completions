#!/usr/bin/env -S deno run --allow-env --allow-run --allow-read --allow-write --allow-net --allow-sys
//MISE description="Sync shell completions for all installed mise tools"
//USAGE flag "--force -f" help="Regenerate all completions regardless of cached version"
//USAGE flag "--verbose -v" help="Print per-tool status"
//USAGE flag "--http-completions" help="Fetch completions from HTTP (e.g. qsv)" negate="--no-http-completions" default=#true
//USAGE flag "--bundled-completions" help="Read completions bundled with tools (e.g. hyperfine)" negate="--no-bundled-completions" default=#true
//USAGE flag "--disable <tools>" help="Skip completion sync for specific tools" var=#true
//USAGE flag "--registry <path>" help="Path to user registry override file (.ts)" env="MISE_SYNC_COMPLETIONS_REGISTRY" default="~/.config/mise/sync-completions/registry.ts"
//USAGE flag "--print-path" help="Print the completions directory path and exit"
//USAGE flag "--shell <shell>" help="Limit sync to a specific shell" {
//USAGE   choices "zsh" "bash" "fish"
//USAGE }

import { join } from 'node:path';
import { homedir } from 'node:os';
import { cli } from './cli.ts';
import { type Shell, VALID_SHELLS } from './shared.ts';

const completionsPath = join(homedir(), '.local', 'share', 'mise-completions');

const expandHome = (path: string) => path.startsWith('~/') ? join(homedir(), path.slice(2)) : path;

const registryPath = expandHome(Deno.env.get('usage_registry')!);

if (Deno.env.get('usage_print_path') === 'true') {
  console.log(completionsPath);
  Deno.exit(0);
}

const rawShell = Deno.env.get('usage_shell') || Deno.env.get('SHELL')?.split('/').at(-1);
if (!rawShell || !VALID_SHELLS.includes(rawShell as Shell)) {
  throw new Error(
    `Cannot determine shell: $SHELL=${Deno.env.get('SHELL') ?? '(unset)'}, pass --shell explicitly`,
  );
}

await cli({
  statePath: join(completionsPath, '.state.json'),
  completionsPath,
  registryPath,
  force: Deno.env.get('usage_force') === 'true',
  verbose: Deno.env.get('usage_verbose') === 'true',
  enableHttpCompletions: Deno.env.get('usage_http_completions') === 'true',
  enableBundledCompletions: Deno.env.get('usage_bundled_completions') === 'true',
  disabledTools: (Deno.env.get('usage_disable') ?? '').split(/\s+/).filter(Boolean),
  shell: rawShell as Shell,
});
